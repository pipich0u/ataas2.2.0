    <div className="ataas-machine-visual">
      <div className="ataas-server-placeholder">
        <EyeOutlined style={{ fontSize: 32, color: '#b8c8e0' }} />
        <span>服务器图片</span>
      </div>
    </div>
    <div className="ataas-machine-metrics">
      <div><span>GPU 使用率</span><strong>{item.gpuUsage}<em>%</em></strong></div>
      <div><span>CPU 使用率</span><strong>{item.cpuUsage}<em>%</em></strong></div>
      <div><span>内存使用率</span><strong>{item.memoryUsage}<em>%</em></strong></div>
      <div><span>磁盘使用率</span><strong>{item.diskUsage}<em>%</em></strong></div>
    </div>
    <div className="ataas-cluster-meta">
      <span>{item.nodes} 节点</span>
      <span>{item.models} 模型</span>
      {item.chips.map((c) => <span key={c}><GpuIcon name={c} />{c}</span>)}
    </div>
  </div>
);

const MiniMetricChart = ({ values, color, height, showAxis }: { values: number[]; color: string; height?: number; showAxis?: boolean }) => {
  const max = Math.max(...values, 1);
  const len = values.length;
  const points = values.map((value, index) => `${(index / Math.max(len - 1, 1)) * 100},${28 - (value / max) * 26}`).join(' ');
  const timeLabels = showAxis ? ['08:00', '10:00', '12:00', '14:00', '16:00'] : [];
  return (
    <div className="ataas-mini-chart" style={height ? { height } : undefined}>
      <div className="ataas-mini-chart-grid" />
      <svg viewBox="0 0 100 30" preserveAspectRatio="none">
        <defs>
          <linearGradient id={`grad-${color.replace('#', '')}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor={color} stopOpacity={0.25} />
            <stop offset="100%" stopColor={color} stopOpacity={0.02} />
          </linearGradient>
        </defs>
        <polyline fill={`url(#grad-${color.replace('#', '')})`} points={`0,28 ${points} 100,28`} />
        <polyline fill="none" stroke={color} strokeWidth="0.5" points={points} />
      </svg>
      {showAxis && <div className="ataas-mini-axis">{timeLabels.map((t, i) => <span key={i}>{t}</span>)}</div>}
    </div>
  );
};

const TopModelCard = ({ item, index, activeMetric }: { item: typeof overviewModelCards[0]; index: number; activeMetric: 'tpm' | 'rpm' }) => {
  return (
    <div className="ataas-model-top-card">
      <div className="ataas-model-top-head">
        <span className="ataas-model-bird">TOP {index + 1}</span>
        <div className="ataas-model-top-name"><CodeSandboxOutlined style={{ fontSize: 14, marginRight: 6, color: '#3370ff' }} /><strong>{item.name}</strong></div>
        <span style={{ color: '#3370ff' }}>{item.token}</span>
      </div>
      <div className="ataas-model-top-stats">
        <div style={{ color: activeMetric === 'rpm' ? '#3370ff' : undefined, fontWeight: activeMetric === 'rpm' ? 600 : undefined }}><span>RPM</span><strong>{item.rpm}</strong></div>
        <div style={{ color: activeMetric === 'tpm' ? '#3370ff' : undefined, fontWeight: activeMetric === 'tpm' ? 600 : undefined }}><span>TPM</span><strong>{item.tpm}</strong></div>
        <div><span>成功率</span><strong>{item.success}</strong></div>
      </div>
      <div className="ataas-model-chart-block">
        <span>TTFT(s)</span>
        <MiniMetricChart values={item.ttft} color="#3370ff" height={60} showAxis />
      </div>
      <div className="ataas-model-chart-block">
        <span>TPOT(s)</span>
        <MiniMetricChart values={item.tpot} color="#3370ff" height={60} showAxis />
      </div>
    </div>
  );
};

